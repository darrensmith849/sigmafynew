# Sigmafy web — required env vars (placeholders only).
# See docs/environment-setup.md for the full table and where each value comes from.

# Database (Neon)
DATABASE_URL=postgres://user:pass@host/db?sslmode=require
DATABASE_URL_SERVICE=postgres://service:pass@host/db?sslmode=require

# Auth (Clerk)
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# AI (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-...
AI_PROVIDER=claude

# Billing (Paystack)
BILLING_PROVIDER=paystack
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...

# Emails (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=no-reply@sigmafy.co

# Cache (Upstash Redis)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Async jobs (Inngest)
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=...

# Storage (Vercel Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Real-time (Pusher)
PUSHER_APP_ID=...
PUSHER_KEY=...
PUSHER_SECRET=...
PUSHER_CLUSTER=eu

# Stats API
STATS_API_BASE_URL=https://stats.sigmafy.internal
STATS_API_SIGNING_SECRET=...

# Observability
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
