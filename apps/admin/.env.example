# Sigmafy admin (2KO platform admin) — required env vars (placeholders only).
# See docs/environment-setup.md for the full table.

# Database (Neon) — admin uses service-role for cross-tenant views, with audit logging.
DATABASE_URL=postgres://user:pass@host/db?sslmode=require
DATABASE_URL_SERVICE=postgres://service:pass@host/db?sslmode=require

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# AI (OpenAI)
OPENAI_API_KEY=sk-...

# Admin allowlist (Phase 0B). Comma-separated emails of 2KO admins. Real
# Clerk org roles in Phase 1.
SIGMAFY_ADMIN_EMAILS=darren@2ko.co.za

# Observability
SENTRY_DSN=https://...@sentry.io/...
