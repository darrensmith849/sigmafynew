{
  "name": "@sigmafy/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "exports": {
    ".": { "types": "./src/index.ts", "default": "./src/index.ts" },
    "./schema": { "types": "./src/schema/index.ts", "default": "./src/schema/index.ts" },
    "./service-role": { "types": "./src/service-role.ts", "default": "./src/service-role.ts" }
  },
  "scripts": {
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "clean": "rm -rf .turbo dist *.tsbuildinfo"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "drizzle-orm": "^0.36.4"
  },
  "devDependencies": {
    "@sigmafy/config": "workspace:*",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
